<Window x:Class="lab4.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Лабораторная работа: Отрезки" Height="400" Width="450"
        WindowStartupLocation="CenterScreen" Background="#F0F0F0">

    <Grid Margin="20">
        <StackPanel>
            <!-- Заголовок -->
            <TextBlock Text="Управление отрезками" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" HorizontalAlignment="Center"/>

            <!-- Ввод данных для отрезка A -->
            <GroupBox Header="Отрезок A" Padding="10" Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="X:" VerticalAlignment="Center" Margin="5,0"/>
                    <TextBox x:Name="AX" Width="80" Text="0"/>
                    <TextBlock Text="Y:" VerticalAlignment="Center" Margin="15,0,5,0"/>
                    <TextBox x:Name="AY" Width="80" Text="10"/>
                </StackPanel>
            </GroupBox>

            <!-- Ввод данных для отрезка B -->
            <GroupBox Header="Отрезок B" Padding="10" Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="X:" VerticalAlignment="Center" Margin="5,0"/>
                    <TextBox x:Name="BX" Width="80" Text="5"/>
                    <TextBlock Text="Y:" VerticalAlignment="Center" Margin="15,0,5,0"/>
                    <TextBox x:Name="BY" Width="80" Text="15"/>
                </StackPanel>
            </GroupBox>

            <!-- Кнопки действий -->
            <UniformGrid Columns="2" Margin="0,10">
                <Button Content="Найти пересечение" Click="OnIntersectClick" Margin="5" Padding="5"/>
                <Button Content="Инвертировать (!)" Click="OnNegateClick" Margin="5" Padding="5"/>
                <Button Content="Сравнить (A > B)" Click="OnCompareClick" Margin="5" Padding="5"/>
                <Button Content="Сложение (A + int)" Click="OnAddClick" Margin="5" Padding="5"/>
            </UniformGrid>

            <!-- Поле вывода результата -->
            <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="3" Background="White" Margin="0,15,0,0" Padding="10">
                <TextBlock x:Name="ResultOutput" 
                           Text="Результат отобразится здесь..." 
                           TextWrapping="Wrap" 
                           FontSize="14" 
                           Foreground="#333333" 
                           FontStyle="Italic"/>
            </Border>
        </StackPanel>
    </Grid>
</Window>